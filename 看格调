-- 实用函数
local function findRoomAtPosition(position)
    if not rooms then return "未知" end
    for _, room in ipairs(rooms:GetChildren()) do
        if room:IsA("Model") and room:FindFirstChild("RoomTrigger") then
            local trigger = room.RoomTrigger
            if trigger:IsA("Part") then
                local region = Region3.new(
                    trigger.Position - trigger.Size/2,
                    trigger.Position + trigger.Size/2
                )
                if position and region:PointInside(position) then
                    return room.Name
                end
            end
        end
    end
    return "未知"
end

local function getColdestRoom()
    if not rooms then return "未知", 0 end
    local coldestRoom = "未知"
    local lowestTemp = 100
    for _, room in ipairs(rooms:GetChildren()) do
        if room:IsA("Model") and room:FindFirstChild("Temperature") then
            local temp = room.Temperature.Value
            if temp < lowestTemp then
                lowestTemp = temp
                coldestRoom = room.Name
            end
        end
    end
    return coldestRoom, lowestTemp
end

local function getCursedObject()
    if not items then return nil end
    for _, item in ipairs(items:GetChildren()) do
        if item:GetAttribute("IsCursed") then
            return item
        end
    end
    return nil
end

-- ESP 函数
local function createEsp(object, name, color, espTable)
    if not object or not object.Parent or not espTable then return end
    
    -- 检查该对象是否已存在ESP
    for _, esp in ipairs(espTable) do
        if esp.Object == object then
            return
        end
    end
    
    local highlight = Instance.new("Highlight")
    highlight.Adornee = object
    highlight.FillTransparency = 0.8
    highlight.OutlineColor = color or Color3.fromRGB(255, 0, 0)
    highlight.OutlineTransparency = 0
    highlight.FillColor = color or Color3.fromRGB(255, 0, 0)
    highlight.Parent = object
    
    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = object
    billboard.Size = UDim2.new(0, 100, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = object
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = name or "物体"
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.Parent = billboard
    
    local espEntry = {
        Object = object,
        Highlight = highlight,
        Billboard = billboard,
        Hue = math.random(0, 360)
    }
    
    table.insert(espTable, espEntry)
    table.insert(espObjects, espEntry)
    
    return espEntry
end

local function clearEsp(espTable)
    for _, v in ipairs(espTable) do
        if v.Highlight and v.Highlight.Parent then
            v.Highlight:Destroy()
        end
        if v.Billboard and v.Billboard.Parent then
            v.Billboard:Destroy()
        end
    end
    table.clear(espTable)
end

local function updateAllESP()
    -- 鬼魂ESP
    if Rayfield.Flags["鬼魂ESP"].CurrentValue and ghost then
        createEsp(ghost, "鬼魂", Color3.fromRGB(255, 0, 0), ghostEspTable)
    else
        clearEsp(ghostEspTable)
    end
    
    -- 诅咒物品ESP
    if Rayfield.Flags["诅咒物品ESP"].CurrentValue then
        local cursedObj = getCursedObject()
        if cursedObj then
            createEsp(cursedObj, "诅咒物品", Color3.fromRGB(255, 0, 255), cursedObjectEspTable)
        end
    else
        clearEsp(cursedObjectEspTable)
    end
    
    -- 发电机ESP
    if Rayfield.Flags["发电机ESP"].CurrentValue and items then
        for _, item in ipairs(items:GetChildren()) do
            if item.Name == "Generator" then
                createEsp(item, "发电机", Color3.fromRGB(0, 255, 0), generatorEspTable)
            end
        end
    else
        clearEsp(generatorEspTable)
    end
    
    -- 玩家ESP
    if Rayfield.Flags["玩家ESP"].CurrentValue then
        for _, player in ipairs(playersService:GetPlayers()) do
            if player ~= localPlayer and player.Character then
                createEsp(player.Character, player.Name, Color3.fromRGB(0, 0, 255), playersEspTable)
            end
        end
    else
        clearEsp(playersEspTable)
    end
end

